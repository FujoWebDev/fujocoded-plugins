{
  "name": "@fujocoded/astro-rehype-html-headings",
  "version": "0.0.2",
  "description": "Adds a list of headings to Astro's frontmatter that include rendered HTML code",
  "keywords": [
    "astro",
    "rehype"
  ],
  "license": "MIT",
  "author": "FujoCoded LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FujoWebDev/fujocoded-plugins.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup index.ts --format cjs,esm --dts --clean",
    "validate": " npx publint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hast-util-heading-rank": "^3.0.0",
    "unist-util-filter": "^5.0.1",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "tsup": "^8.1.0",
    "typescript": "^5.6.2",
    "unified": "^11.0.4"
  }
}
