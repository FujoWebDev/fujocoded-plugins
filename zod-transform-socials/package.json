{
  "name": "@fujocoded/zod-transform-socials",
  "version": "0.0.14",
  "description": "A Zod schema + transformer for social URLs",
  "keywords": [
    "zod"
  ],
  "license": "MIT",
  "author": "FujoCoded LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FujoWebDev/fujocoded-plugins.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup index.ts --format cjs,esm --dts --clean",
    "validate": " npx publint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "social-links": "^1.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.5.2"
  }
}
