# Copy the local `file:../..` package into node_modules instead of symlinking it.
# Without this, Node resolves the package's `import "zod"` against its own
# `node_modules/zod` (v4 from its devDependencies) instead of this consumer's
# zod@3, mixing Zod versions and crashing at runtime with
# `keyValidator._parse is not a function` when SocialLinks is embedded in a
# Zod 3 z.object(). A real `npm install` from the registry has no nested
# node_modules so this flag is only needed for local file: links.
install-links=true
