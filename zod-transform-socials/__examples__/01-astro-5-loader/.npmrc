# Copy the local `file:../..` package into node_modules instead of symlinking it.
# Without this, Node would resolve the package's `import "zod"` against its own
# nested `node_modules/zod` (v4 from its devDependencies) instead of this
# consumer's zod@3, mixing Zod versions. Vite/Astro's bundler dedupes the two
# at build time so the example still works without this flag — but copying
# makes resolution deterministic and matches what a real registry install
# (no nested node_modules) would do.
install-links=true
